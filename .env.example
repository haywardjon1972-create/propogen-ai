# --- SpaceXAI / xAI (live AI generation for Pro users) ---
# https://console.x.ai
XAI_API_KEY=

# --- Stripe (Pro checkout) ---
# https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_ / sk_test_) while developing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional: existing Stripe Price ID for a subscription product.
# If empty, Checkout uses a $19 one-time "Propogen AI Pro" payment.
STRIPE_PRICE_ID=

# Optional: webhook signing secret from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=

# Optional: secret used to sign the Pro access cookie (defaults to STRIPE_SECRET_KEY)
PRO_COOKIE_SECRET=

# Public site URL (required for correct Stripe redirect on production)
# Example: https://propogen-ai-y8qb.vercel.app
NEXT_PUBLIC_APP_URL=

# Local only: skip Stripe and treat everyone as Pro
# PRO_ACCESS_BYPASS=true

# --- Instagram auto-post (Meta Graph API) ---
# See marketing/instagram-auto-post-setup.md
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional public https image used when publish has no imageUrl
INSTAGRAM_DEFAULT_IMAGE_URL=
# Password for https://yoursite/admin/social
SOCIAL_ADMIN_SECRET=
